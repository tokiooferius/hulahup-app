    "phase_1_local_preparation": {
      "description": "Persiapan file lokal sebelum push",
      "duration": "5-10 menit",
      "tasks": [
        {
          "task": "Initialize Git Repository",
          "command": "git init",
          "completed": false,
          "notes": "Skip jika sudah ada .git folder"
        },
        {
          "task": "Setup Git Config",
          "command": "git config user.name 'Your Name' && git config user.email 'your@email.com'",
          "completed": false
        },
        {
          "task": "Install Composer Dependencies",
          "command": "composer install --optimize-autoloader --no-dev",
          "completed": false,
          "notes": "Untuk production, gunakan --no-dev"
        },
        {
          "task": "Install Node Dependencies",
          "command": "npm install",
          "completed": false
        },
        {
          "task": "Build Frontend Assets",
          "command": "npm run build",
          "completed": false,
          "notes": "Generate /public/build directory"
        },
        {
          "task": "Generate Application Key",
          "command": "php artisan key:generate --show",
          "completed": false,
          "notes": "Simpan APP_KEY untuk production"
        },
        {
          "task": "Cache Configuration",
          "command": "php artisan config:cache && php artisan route:cache",
          "completed": false,
          "notes": "Performance optimization"
        },
        {
          "task": "Verify Local Database",
          "command": "php artisan migrate",
          "completed": false,
          "notes": "Pastikan MySQL local running"
        }
      ]
    },
    
    "phase_2_github_setup": {
      "description": "Push code ke GitHub",
      "duration": "5 menit",
      "tasks": [
        {
          "task": "Create GitHub Repository",
          "url": "https://github.com/new",
          "completed": false,
          "details": {
            "name": "hulahup-app",
            "description": "Canteen Order System",
            "visibility": "public"
          }
        },
        {
          "task": "Add Remote Origin",
          "command": "git remote add origin https://github.com/USERNAME/hulahup-app.git",
          "completed": false,
          "notes": "Replace USERNAME dengan GitHub username Anda"
        },
        {
          "task": "Stage All Files",
          "command": "git add .",
          "completed": false
        },
        {
          "task": "Create Initial Commit",
          "command": "git commit -m 'Initial commit: Hulahup App - Canteen Order System'",
          "completed": false
        },
        {
          "task": "Rename to Main Branch",
          "command": "git branch -M main",
          "completed": false
        },
        {
          "task": "Push to GitHub",
          "command": "git push -u origin main",
          "completed": false,
          "notes": "First push memerlukan GitHub authentication"
        }
      ]
    },
    
