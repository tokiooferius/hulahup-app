          "command": "php artisan migrate --force",
          "completed": false
        },
        {
          "task": "Seed Database (Optional)",
          "command": "php artisan db:seed --force",
          "completed": false,
          "notes": "Jika ingin data demo"
        },
        {
          "task": "Create Storage Link",
          "command": "php artisan storage:link",
          "completed": false,
          "notes": "Untuk upload file user"
        },
        {
          "task": "Cache Config di Production",
          "command": "php artisan config:cache",
          "completed": false
        },
